// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户角色枚举
enum UserRole {
  OWNER      // 车位业主
  TENANT     // 车位租户
  ADMIN      // 管理员
}

// 用户模型
model User {
  id            String    @id @default(cuid())
  phone         String    @unique
  wxOpenid      String?   @unique @map("wx_openid")
  role          UserRole  @default(TENANT)
  name          String?
  avatar        String?
  referralCode  String?   @unique @map("referral_code")
  referredBy    String?   @map("referred_by")
  referralRewards Decimal @default(0) @map("referral_rewards") @db.Decimal(10, 2)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // 关系
  ownedSpots    ParkingSpot[] @relation("OwnerSpots")
  orders        Order[]       @relation("TenantOrders")
  sentReferrals ReferralRecord[] @relation("Referrer")
  receivedReferrals ReferralRecord[] @relation("Referee")

  @@map("users")
}

// 车位状态枚举
enum SpotStatus {
  AVAILABLE    // 可租
  RENTED       // 已租
  UNAVAILABLE  // 暂不出租
}

// 车位模型
model ParkingSpot {
  id            String      @id @default(cuid())
  ownerId       String      @map("owner_id")
  title         String
  address       String
  longitude     Float
  latitude      Float
  pricePerHour  Decimal     @map("price_per_hour") @db.Decimal(10, 2)
  description   String?
  images        String[]    @default([])
  status        SpotStatus  @default(AVAILABLE)
  availableFrom DateTime?   @map("available_from")  // 每日可租开始时间
  availableTo   DateTime?   @map("available_to")    // 每日可租结束时间
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  // 关系
  owner         User        @relation("OwnerSpots", fields: [ownerId], references: [id])
  orders        Order[]

  @@index([longitude, latitude])
  @@index([status])
  @@map("parking_spots")
}

// 订单状态枚举
enum OrderStatus {
  PENDING      // 待确认
  CONFIRMED    // 已确认
  IN_PROGRESS  // 进行中
  COMPLETED    // 已完成
  CANCELLED    // 已取消
  REJECTED     // 已拒绝
}

// 订单模型
model Order {
  id            String      @id @default(cuid())
  spotId        String      @map("spot_id")
  tenantId      String      @map("tenant_id")
  startTime     DateTime    @map("start_time")
  endTime       DateTime    @map("end_time")
  totalPrice    Decimal     @map("total_price") @db.Decimal(10, 2)
  status        OrderStatus @default(PENDING)
  note          String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  // 关系
  spot          ParkingSpot @relation(fields: [spotId], references: [id])
  tenant        User        @relation("TenantOrders", fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([spotId])
  @@index([status])
  @@map("orders")
}

// 邀请记录模型
model ReferralRecord {
  id            String    @id @default(cuid())
  referrerId    String    @map("referrer_id")
  refereeId     String    @map("referee_id")
  rewardAmount  Decimal   @default(0) @map("reward_amount") @db.Decimal(10, 2)
  status        String    @default("pending")
  triggeredByOrderId String? @map("triggered_by_order_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  rewardedAt    DateTime? @map("rewarded_at")

  // 关系
  referrer      User      @relation("Referrer", fields: [referrerId], references: [id])
  referee       User      @relation("Referee", fields: [refereeId], references: [id])

  @@unique([refereeId])
  @@index([referrerId])
  @@index([status])
  @@map("referral_records")
}

// 分析事件模型
model AnalyticsEvent {
  id          String   @id @default(cuid())
  event       String   // 事件名称
  properties  Json     @default("{}") @map("properties") // 事件属性
  userId      String?  @map("user_id")
  sessionId   String   @map("session_id")
  pathname    String   @map("pathname") // 页面路径
  userAgent   String?  @map("user_agent")
  referrer    String?  @map("referrer")
  ip          String?  @map("ip") // IP地址
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([event])
  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
  @@index([pathname])
  @@map("analytics_events")
}
